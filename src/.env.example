APP_NAME="mini-RAG"
APP_VERSION="0.1.0"

FILE_ALLOWED_TYPES=["text/plain", "application/pdf"]
FILE_MAX_SIZE=10
FILE_DEFAULT_CHUNK_SIZE=512000  # 512 KB

MONGODB_URL="mongodb://@username:password@localhost:27007"
MONGODB_DATABASE="mini-rag"

# LLM Configurations
GENERATION_BACKEND = "openai"
EMBEDDING_BACKEND = "cohere"

GENERATION_MODEL_ID = "gpt-3.5-turbo-0125"
EMBEDDING_MODEL_ID = "embed-multilingual-light-v3.0"
EMBEDDING_MODEL_SIZE=384
INPUT_DEFAULT_MAX_CHARACTERS = 2048
GENERATION_DEFAULT_MAX_TOKENS = 2048
GENERATION_DEFAULT_TEMPERATURE = 0.2

# OpenAI Configurations
OPENAI_API_KEY="your-openai-api-key"

# Cohere Configurations
COHERE_API_KEY="your-cohere-api-key"